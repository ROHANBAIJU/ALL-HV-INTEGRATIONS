# ═══════════════════════════════════════════════════════════════════════════
# UNIFIED HYPERVERGE BACKEND - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file to version control!

# ═══════════════════════════════════════════════════════════════════════════
# DEFAULT MODE CREDENTIALS
# ═══════════════════════════════════════════════════════════════════════════
# These credentials are used when apps make requests in "default" mode
# Get these from your HyperVerge Dashboard

DEFAULT_APP_ID=c52h5j
DEFAULT_APP_KEY=HV:q7aqkdhe5b39vfmeg
DEFAULT_WORKFLOW_ID=rb_sureguard_insurance

# ═══════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=development

# Base URL for file uploads (used to generate file URLs)
# For local: http://localhost:3000
# For production: https://your-app.vercel.app
BASE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# HYPERVERGE API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# HyperVerge Authentication API endpoint (Recommended method)
HYPERVERGE_AUTH_URL=https://ind-state.idv.hyperverge.co/v2/auth/token

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Frontend URL for CORS (if needed)
FRONTEND_URL=

# Webhook secret for signature verification (if HyperVerge provides one)
WEBHOOK_SECRET=
